[b5] apad [b6];
[b6] atrim=start_sample=0:end_sample=48000, asetpts=PTS-STARTPTS [b7];
[voicelane] asplit=3 [vc8][vc9][vc10];
[b4][vc9] sidechaincompress=threshold=0.05:ratio=8:attack=20:release=300:makeup=1:knee=2.82843 [bd11];
[b7][vc10] sidechaincompress=threshold=0.05:ratio=8:attack=20:release=300:makeup=1:knee=2.82843 [bd12];
[vc8] volume=0dB [vg13];
[bd11] volume=-12dB [bg14];
