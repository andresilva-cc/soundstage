{
  "name": "soundstage",
  "version": "0.1.0",
  "description": "Audio as Code — compose narrated audio episodes with JSX/TSX",
  "keywords": [
    "audio",
    "audio-as-code",
    "tts",
    "text-to-speech",
    "jsx",
    "tsx",
    "podcast",
    "voiceover",
    "ffmpeg",
    "kokoro"
  ],
  "homepage": "https://github.com/andresilva-cc/soundstage#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andresilva-cc/soundstage.git"
  },
  "bugs": {
    "url": "https://github.com/andresilva-cc/soundstage/issues"
  },
  "author": "André Silva (https://github.com/andresilva-cc)",
  "type": "module",
  "license": "MIT",
  "bin": {
    "soundstage": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.ts",
      "import": "./dist/jsx-runtime/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "postbuild": "chmod +x dist/cli/index.js",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "esbuild": "^0.25.0",
    "node-id3": "^0.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.6",
    "elevenlabs": "^1.0.0",
    "eslint": "^9.17.0",
    "kokoro-js": "^1.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "elevenlabs": "^1.0.0",
    "kokoro-js": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "elevenlabs": {
      "optional": true
    },
    "kokoro-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
