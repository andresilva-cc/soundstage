[c1] anull [voicelane];
[1:a] aresample=48000, aformat=sample_fmts=fltp:channel_layouts=mono:sample_rates=48000 [b2];
[b2] apad [b3];
[b3] atrim=start_sample=0:end_sample=48000, asetpts=PTS-STARTPTS [b4];
