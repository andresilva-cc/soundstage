// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AC1: single voice clip > emits aresample+aformat conditioning and atrim/asetpts — snapshot 1`] = `
"[0:a] aresample=48000, aformat=sample_fmts=fltp:channel_layouts=mono:sample_rates=48000 [c0];
[c0] atrim=start_sample=0:end_sample=48000, asetpts=PTS-STARTPTS [c1];
[c1] anull [voicelane];"
`;

exports[`AC2: two sequential clips > emits adelay=NS:all=1 for the second clip — snapshot 1`] = `
"[0:a] aresample=48000, aformat=sample_fmts=fltp:channel_layouts=mono:sample_rates=48000 [c0];
[c0] atrim=start_sample=0:end_sample=24000, asetpts=PTS-STARTPTS [c1];
[1:a] aresample=48000, aformat=sample_fmts=fltp:channel_layouts=mono:sample_rates=48000 [c3];
[c3] atrim=start_sample=0:end_sample=48000, asetpts=PTS-STARTPTS [c4];
[c4] adelay=delays=24000S:all=1 [c5];
[c5] asetpts=PTS-STARTPTS [c6];
[c1][c6] amix=inputs=2:normalize=0:dropout_transition=0 [c2];
[c2] anull [voicelane];"
`;

exports[`AC3: crossfade between two clips > emits acrossfade=ns=N:c1=tri:c2=tri — snapshot 1`] = `
"[0:a] aresample=48000, aformat=sample_fmts=fltp:channel_layouts=mono:sample_rates=48000 [c0];
[c0] atrim=start_sample=0:end_sample=48000, asetpts=PTS-STARTPTS [c1];
[1:a] aresample=48000, aformat=sample_fmts=fltp:channel_layouts=mono:sample_rates=48000 [c3];
[c3] atrim=start_sample=0:end_sample=48000, asetpts=PTS-STARTPTS [c4];
[c1][c4] acrossfade=ns=36000:c1=tri:c2=tri [c2];
[c2] anull [voicelane];"
`;

exports[`AC4: three clips with two crossfades fold left-to-right > emits two acrossfade invocations — snapshot 1`] = `
