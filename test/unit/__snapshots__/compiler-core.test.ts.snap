[2:a] aresample=48000, aformat=sample_fmts=fltp:channel_layouts=mono:sample_rates=48000 [c6];
[c6] atrim=start_sample=0:end_sample=48000, asetpts=PTS-STARTPTS [c7];
[c2][c7] acrossfade=ns=24000:c1=tri:c2=tri [c5];
[c5] anull [voicelane];"
`;

exports[`AC5: silence clip > emits aevalsrc=0 with atrim+asetpts for sample-exact silence — no input file — snapshot 1`] = `
"aevalsrc=0:s=48000:d=2, atrim=end_sample=96000, asetpts=PTS-STARTPTS [sil0];
[sil0] anull [voicelane];"
`;

